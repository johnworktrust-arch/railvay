TELEGRAM_BOT_TOKEN=put-your-telegram-bot-token-here
# Local development:
DATABASE_URL=sqlite:///./data/ceai.sqlite3
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Production/Railway refuses SQLite by default because container files can be reset on deploy.
# Use only for disposable test bots:
# CEAI_ALLOW_EPHEMERAL_SQLITE=1
APP_ENV=local
MOCK_PAYMENT_BASE_URL=https://mock-payments.local/pay
PAYMENT_PROVIDER=mock
# For real payments set PAYMENT_PROVIDER=yookassa and fill these values from YooKassa.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_WEBHOOK_PATH=/payments/yookassa/webhook
YOOKASSA_RETURN_PATH=/payments/yookassa/return
YOOKASSA_REQUEST_TIMEOUT_SECONDS=15
# Crypto Pay through @CryptoBot / @CryptoTestnetBot.
# For testnet use https://testnet-pay.crypt.bot/api.
# For production use https://pay.crypt.bot/api.
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_API_BASE=https://testnet-pay.crypt.bot/api
CRYPTO_PAY_WEBHOOK_SECRET=change-this-long-random-secret
CRYPTO_PAY_WEBHOOK_PATH=/payments/crypto/webhook
CRYPTO_PAY_ACCEPTED_ASSETS=USDT
CRYPTO_PAY_REQUEST_TIMEOUT_SECONDS=15
# Optional fixed Telegram Stars invoice amount for tests.
# Leave 0 in production: tariff Stars are calculated as roughly 1⭐ = 2₽.
TELEGRAM_STARS_AMOUNT=0
# Optional. On Railway the app uses https://$RAILWAY_PUBLIC_DOMAIN/public-offer by default.
# URL пользовательского соглашения. Старое имя сохранено для совместимости.
PUBLIC_OFFER_URL=https://telegra.ph/Polzovatelskoe-soglashenie-Cea-AI-07-16
PRIVACY_POLICY_URL=https://telegra.ph/Politika-konfidencialnosti-Cea-AI-07-16
INFO_CHANNEL_URL=https://t.me/ceafamily
SUPPORT_USERNAME=cea_help
ADMIN_TELEGRAM_IDS=
# Username bootstrap exists for cases where numeric Telegram ID is not known yet.
ADMIN_TELEGRAM_USERNAMES=samescam
AI_PROVIDER_MODE=auto
AI_REQUEST_TIMEOUT_SECONDS=60
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_IMAGE_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
KLING_API_KEY=
# Also accepted if you already named the variable differently:
# KLINGAI_API_KEY=, KLING_AI_API_KEY=, KLING_KEY=, KLING_TOKEN=
KLING_BASE_URL=https://api-singapore.klingai.com
KLING_POLL_INTERVAL_SECONDS=10
KLING_POLL_TIMEOUT_SECONDS=600
# Railway sets PORT automatically. Leave it empty locally.
# PORT=8080

# Set APP_BASE_URL in production to use Telegram webhooks instead of polling.
# Railway automatically provides RAILWAY_PUBLIC_DOMAIN after you generate a domain.
# You can leave APP_BASE_URL empty on Railway, or set it manually:
# APP_BASE_URL=https://your-service.up.railway.app
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=change-me

# CEA VPN bot and the outbound-only VPS provisioning worker.
VPN_TELEGRAM_BOT_TOKEN=
VPN_BOT_USERNAME=ceavpn_bot
VPN_TELEGRAM_WEBHOOK_PATH=/telegram/vpn/webhook
VPN_TELEGRAM_WEBHOOK_SECRET=change-this-telegram-webhook-secret
VPN_CHANNEL_URL=https://t.me/ceafamily
VPN_SUPPORT_USERNAME=cea_help
VPN_SERVER_CODE=nl-1
VPN_WORKER_ID=cea-vpn-nl1
# Use a different cryptographically random value of at least 32 characters.
VPN_WORKER_SECRET=change-this-long-random-worker-secret
VPN_SUBSCRIPTION_BASE_URL=https://sub.79-137-197-51.sslip.io:8443
VPN_TRIAL_DAYS=3
# Personal fake-payment sandbox. Keep disabled outside an admin-only test.
VPN_ALLOW_ADMIN_DEMO_PAYMENT=0
# Numeric Telegram IDs only; usernames are intentionally not accepted here.
VPN_ADMIN_DEMO_TELEGRAM_IDS=
VPN_WORKER_CLOCK_SKEW_SECONDS=300
VPN_WORKER_LEASE_SECONDS=120
VPN_MAINTENANCE_INTERVAL_SECONDS=60
