TELEGRAM_BOT_TOKEN=put-your-telegram-bot-token-here
# Local development:
DATABASE_URL=sqlite:///./data/ceai.sqlite3
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Production/Railway refuses SQLite by default because container files can be reset on deploy.
# Use only for disposable test bots:
# CEAI_ALLOW_EPHEMERAL_SQLITE=1
APP_ENV=local
MOCK_PAYMENT_BASE_URL=https://mock-payments.local/pay
PAYMENT_PROVIDER=mock
# For real payments set PAYMENT_PROVIDER=yookassa and fill these values from YooKassa.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_BASE_URL=https://api.yookassa.ru/v3
YOOKASSA_WEBHOOK_PATH=/payments/yookassa/webhook
YOOKASSA_RETURN_PATH=/payments/yookassa/return
YOOKASSA_REQUEST_TIMEOUT_SECONDS=15
# Crypto Pay through @CryptoBot / @CryptoTestnetBot.
# For testnet use https://testnet-pay.crypt.bot/api.
# For production use https://pay.crypt.bot/api.
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_API_BASE=https://testnet-pay.crypt.bot/api
CRYPTO_PAY_WEBHOOK_SECRET=change-this-long-random-secret
CRYPTO_PAY_WEBHOOK_PATH=/payments/crypto/webhook
CRYPTO_PAY_ACCEPTED_ASSETS=USDT
CRYPTO_PAY_REQUEST_TIMEOUT_SECONDS=15
# Optional. On Railway the app uses https://$RAILWAY_PUBLIC_DOMAIN/public-offer by default.
# PUBLIC_OFFER_URL=https://your-service.up.railway.app/public-offer
INFO_CHANNEL_URL=https://t.me/ceafamily
SUPPORT_USERNAME=cea_help
ADMIN_TELEGRAM_IDS=
# Username bootstrap exists for cases where numeric Telegram ID is not known yet.
ADMIN_TELEGRAM_USERNAMES=samescam
AI_PROVIDER_MODE=auto
AI_REQUEST_TIMEOUT_SECONDS=60
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_IMAGE_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Railway sets PORT automatically. Leave it empty locally.
# PORT=8080

# Set APP_BASE_URL in production to use Telegram webhooks instead of polling.
# Railway automatically provides RAILWAY_PUBLIC_DOMAIN after you generate a domain.
# You can leave APP_BASE_URL empty on Railway, or set it manually:
# APP_BASE_URL=https://your-service.up.railway.app
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=change-me
