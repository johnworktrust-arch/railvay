TELEGRAM_BOT_TOKEN=put-your-telegram-bot-token-here
# Local development:
DATABASE_URL=sqlite:///./data/ceai.sqlite3
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
APP_ENV=local
MOCK_PAYMENT_BASE_URL=https://mock-payments.local/pay
PUBLIC_OFFER_URL=https://ceaai-bot.onrender.com/public-offer
INFO_CHANNEL_URL=https://t.me/cea_family
SUPPORT_USERNAME=cea_help
ADMIN_TELEGRAM_IDS=
# Username bootstrap exists for cases where numeric Telegram ID is not known yet.
ADMIN_TELEGRAM_USERNAMES=samescam
AI_PROVIDER_MODE=auto
AI_REQUEST_TIMEOUT_SECONDS=60
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Northflank sets PORT automatically. Leave it empty locally.
# PORT=8080

# Set APP_BASE_URL in production to use Telegram webhooks instead of polling.
# APP_BASE_URL=https://ceaai-bot.onrender.com
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=change-me
