# Install as /etc/ceavpn/worker.env with owner root:root and mode 0600.
# Generate a secret, for example: openssl rand -base64 48
VPN_WORKER_ID=cea-vpn-nl1
VPN_WORKER_SECRET=replace-with-at-least-32-random-bytes

# Existing public Railway service. HTTPS is mandatory.
VPN_RAILWAY_BASE_URL=https://replace-with-service.up.railway.app
VPN_WORKER_CLAIM_PATH=/internal/vpn/worker/claim
VPN_WORKER_RESULT_PATH=/internal/vpn/worker/result
VPN_WORKER_FAIL_PATH=/internal/vpn/worker/fail

# Public subscription origin, shared with Railway. Only its /sub/* URLs pass.
VPN_SUBSCRIPTION_BASE_URL=https://sub.replace.example:8443

# The Marzban API must remain loopback-only. Remote URLs are rejected.
MARZBAN_BASE_URL=http://127.0.0.1:8000
MARZBAN_BOT_USERNAME=replace-with-non-sudo-worker-admin
MARZBAN_BOT_PASSWORD=replace-with-a-long-random-password
# Comma-separated. If unset, the legacy MARZBAN_INBOUND_TAG is still accepted.
MARZBAN_INBOUND_TAGS=VLESS TCP REALITY,VLESS WS TLS FALLBACK

VPN_WORKER_POLL_INTERVAL_SECONDS=3
VPN_WORKER_HTTP_TIMEOUT_SECONDS=15
VPN_WORKER_LEASE_SECONDS=120
VPN_WORKER_LOG_LEVEL=INFO
